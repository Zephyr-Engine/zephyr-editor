[material]
shader = "shaders/basic"

[render_state]
alpha_mode = "solid"

[texture.albedo]
path = "textures/brick_albedo.jpg"
resource = "u_albedo"

[param.u_base_color]
value = [1.0, 1.0, 1.0, 1.0]

[param.u_uv_scale]
value = [8.0, 8.0]

[param.u_metallic]
value = 0.0

[param.u_roughness]
value = 0.65

[param.u_emissive]
value = [0.0, 0.0, 0.0]
